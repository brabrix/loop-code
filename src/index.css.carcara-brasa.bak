@import '@fontsource-variable/hanken-grotesk';
@import '@fontsource-variable/jetbrains-mono';

@tailwind base;
@tailwind components;
@tailwind utilities;

/* ─────────────────────────────────────────────────────────────────────────
   Identidade Carcará Code
   Ancorada no carcará (ave de rapina do sertão): plumagem escura, o sol e a
   terra ocre da caatinga, e o traço marcante da PELE FACIAL alaranjada/vermelha.
   Daí: canvas "carvão quente" (não o cinza-azulado genérico) + acento "brasa".
   Tudo num só hue quente; o laranja é a única cor saturada — é a assinatura.
   ───────────────────────────────────────────────────────────────────────── */
@layer base {
  :root {
    /* Tema claro — "papel do sertão": areia quente, não branco estéril. */
    --background: 40 30% 96%;
    --foreground: 28 28% 13%;
    --card: 42 42% 99%;
    --card-foreground: 28 28% 13%;
    --popover: 42 42% 99%;
    --popover-foreground: 28 28% 13%;
    --primary: 19 88% 49%;
    --primary-foreground: 40 50% 98%;
    --secondary: 38 26% 91%;
    --secondary-foreground: 26 30% 20%;
    --muted: 38 24% 92%;
    --muted-foreground: 28 13% 40%;
    --accent: 30 44% 89%;
    --accent-foreground: 22 40% 22%;
    --destructive: 8 72% 48%;
    --destructive-foreground: 40 50% 98%;
    /* Âmbar de alerta — "Parar". Quente como a brasa, mas mais dourado (hue ~38)
       pra ler como "atenção", não como erro (esse é o --destructive). */
    --warning: 36 92% 44%;
    --border: 36 20% 83%;
    --input: 36 20% 85%;
    --ring: 19 88% 49%;
    --radius: 0.5rem;

    --font-ui: 'Hanken Grotesk Variable', ui-sans-serif, system-ui, 'Segoe UI', sans-serif;
    --font-mono: 'JetBrains Mono Variable', ui-monospace, 'Cascadia Code', Consolas, monospace;
  }

  .dark {
    /* Tema escuro — "carvão quente": near-black com hue quente (~28), não o
       cinza-azulado de VS Code. Camadas com luminosidade distinta = contraste
       de verdade. O laranja "brasa" aparece só como destaque (--primary/--ring). */
    --background: 30 9% 9%;
    --foreground: 38 26% 90%;
    --card: 28 9% 12%;
    --card-foreground: 38 26% 90%;
    --popover: 28 9% 14%;
    --popover-foreground: 38 26% 90%;
    --primary: 22 90% 56%;
    --primary-foreground: 26 60% 9%;
    --secondary: 28 8% 21%;
    --secondary-foreground: 38 24% 92%;
    --muted: 28 8% 17%;
    --muted-foreground: 34 15% 64%;
    --accent: 26 10% 24%;
    --accent-foreground: 38 24% 94%;
    --destructive: 8 64% 48%;
    --destructive-foreground: 40 50% 97%;
    /* Âmbar de alerta — "Parar". Quente como a brasa, mas mais dourado (hue ~42)
       pra ler como "atenção", não como erro (esse é o --destructive). */
    --warning: 42 95% 58%;
    --border: 30 9% 23%;
    --input: 28 9% 17%;
    --ring: 22 90% 56%;
  }
}

@layer base {
  * {
    @apply border-border;
  }
  html,
  body,
  #root {
    height: 100%;
  }
  body {
    @apply bg-background text-foreground;
    margin: 0;
    overflow: hidden;
    font-family: var(--font-ui);
    /* Nitidez "trabalhada": antialias + kerning/ligaturas, sem peso visual extra. */
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    letter-spacing: -0.006em;
  }
  code,
  pre,
  kbd,
  .font-mono {
    font-family: var(--font-mono);
  }
  /* Seleção na cor "brasa" — pequeno toque de identidade em todo o app. */
  ::selection {
    background: hsl(var(--primary) / 0.28);
  }
}

@layer components {
  /* "Eyebrow": rótulo de seção em caixa-alta espaçada. Estrutura que informa
     (REQUESTS, RESPOSTA, PARAMS…) e dá personalidade no lugar do texto solto. */
  .eyebrow {
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
  }
}

/* Scrollbar fina e custom (estilo Lovable / Chrome atual): ocupa pouco espaço,
   thumb arredondado que aparece sobre um trilho discreto e acompanha o tema.
   Some das setas grossas do scrollbar nativo. */
* {
  scrollbar-width: thin; /* Firefox */
  scrollbar-color: hsl(var(--muted-foreground) / 0.35) transparent;
}
::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}
::-webkit-scrollbar-track {
  background: transparent;
}
::-webkit-scrollbar-thumb {
  background-color: hsl(var(--muted-foreground) / 0.32);
  border: 2px solid transparent; /* "afina" o thumb deixando uma folga ao redor */
  border-radius: 9999px;
  background-clip: padding-box;
}
::-webkit-scrollbar-thumb:hover {
  background-color: hsl(var(--muted-foreground) / 0.55);
}
::-webkit-scrollbar-corner {
  background: transparent;
}
/* Remove as setas (botões) grossas do topo/baixo. */
::-webkit-scrollbar-button {
  display: none;
  width: 0;
  height: 0;
}

/* Esconde o scrollbar nativo (a rolagem continua pela roda/trackpad).
   Usado no rail de ícones: o scrollbar de 10px roubava o espaço da direita
   e cortava a bolinha de status que se projeta para fora do ícone. */
.no-scrollbar {
  scrollbar-width: none; /* Firefox */
}
.no-scrollbar::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
}

/* Fundo quadriculado pra enxergar a transparência das imagens. */
.ygc-checker {
  background-color: #fff;
  background-image:
    linear-gradient(45deg, #e5e7eb 25%, transparent 25%),
    linear-gradient(-45deg, #e5e7eb 25%, transparent 25%),
    linear-gradient(45deg, transparent 75%, #e5e7eb 75%),
    linear-gradient(-45deg, transparent 75%, #e5e7eb 75%);
  background-size: 20px 20px;
  background-position: 0 0, 0 10px, 10px -10px, -10px 0;
}
